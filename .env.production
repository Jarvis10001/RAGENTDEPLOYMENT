# Production Environment Variables Template
# Copy this to your Render environment or use as reference

# ── Supabase (PostgreSQL + pgvector) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Google Gemini LLM & Embeddings ────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-from-aistudio.google.com

# ── Cohere Reranking API (free tier available) ────────────────────
COHERE_API_KEY=your-cohere-api-key-from-cohere.com

# ── Tavily Web Search API ─────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key

# ── Frontend URL (set to your Vercel deployment URL) ──────────────
FRONTEND_URL=https://ragentdeployment-xxxxx.vercel.app

# ── LLM Model Configuration ───────────────────────────────────────
PRIMARY_MODEL=gemini-3.1-flash-lite-preview
SUB_AGENT_MODEL=gemini-3.1-flash-lite-preview
PRIMARY_MAX_TOKENS=2048
SUB_AGENT_MAX_TOKENS=600
ENABLE_CLASSIFIER=true

# ── Reranker Configuration ────────────────────────────────────────
RERANKER_MODEL=rerank-english-v3.0

# ── Embeddings Configuration ─────────────────────────────────────
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Caching (set to false for ephemeral filesystems like Render) ──
CACHE_ENABLED=false
CACHE_DIR=.cache/responses
CACHE_TTL_SECONDS=3600
TAVILY_CACHE_TTL_SECONDS=1800

# ── RAG Configuration ─────────────────────────────────────────────
RAG_RETRIEVE_K=20
RAG_RERANK_K=5

# ── Tavily Search Configuration ───────────────────────────────────
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Observability ────────────────────────────────────────────────
PHOENIX_ENABLED=false
