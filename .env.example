# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...your-service-role-key

# ── LLM Provider ─────────────────────────────────────────
# Get a free API key at https://console.groq.com (30 req/min free tier)
GROQ_API_KEY=gsk_your_key_here

# ── Model Selection ──────────────────────────────────────
# 8B for fast classification, 70B for reasoning-heavy agents
ROUTER_MODEL_NAME=groq/llama-3.1-8b-instant
ANALYST_MODEL_NAME=groq/llama-3.3-70b-versatile
RAG_MODEL_NAME=groq/llama-3.3-70b-versatile
SYNTHESIS_MODEL_NAME=groq/llama-3.3-70b-versatile

# ── Embedding Model ─────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Reranker Model ──────────────────────────────────────
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── RAG Settings ────────────────────────────────────────
VECTOR_SEARCH_TOP_K=20
RERANKER_TOP_K=5

# ── SQL Tool ────────────────────────────────────────────
MAX_SQL_ROWS=15

# ── Chunking Settings ──────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Arize Phoenix Observability ─────────────────────────
PHOENIX_ENDPOINT=http://localhost:6006
PHOENIX_ENABLED=true

# ── Session Memory ──────────────────────────────────────
MEMORY_MAX_TOKEN_LIMIT=2000

# ── Application ─────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
