# ── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...your-service-role-key

# ── Google Gemini ────────────────────────────────────────────────────
# Free API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── Tavily Web Search ────────────────────────────────────────────────
# Free API key: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Model Selection ──────────────────────────────────────────────────
# Using Gemini 3.1 Flash Lite Preview
PRIMARY_MODEL=gemini-3.1-flash-lite-preview
SUB_AGENT_MODEL=gemini-3.1-flash-lite-preview
PRIMARY_MAX_TOKENS=2048
SUB_AGENT_MAX_TOKENS=600

# ── Embedding & Reranker (local — no API key needed) ─────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── RAG Settings ─────────────────────────────────────────────────────
RAG_RETRIEVE_K=20
RAG_RERANK_K=5

# ── SQL Tool ─────────────────────────────────────────────────────────
MAX_SQL_ROWS=10

# ── Tavily Settings ──────────────────────────────────────────────────
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

# ── Cache ────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DIR=.cache/responses
CACHE_TTL_SECONDS=3600
TAVILY_CACHE_TTL_SECONDS=1800

# ── Session Memory ───────────────────────────────────────────────────
MEMORY_MAX_TOKEN_LIMIT=2000
ENABLE_CLASSIFIER=true

# ── Observability (optional) ─────────────────────────────────────────
PHOENIX_ENABLED=false

# ── Application ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
